# ───────────────────────── Sensitive data ─────────────────────────
# Never commit secrets, credentials, or signing material.

# Runtime credential store read by CredentialStore.swift
# (~/Library/Application Support/MacRDP/credentials.json or any in-repo copy)
credentials.json
**/credentials.json

# Environment / secret files
.env
.env.*
*.local.xcconfig
secrets.xcconfig
*.secret
*.secrets

# Code-signing & provisioning material
*.p12
*.pfx
*.cer
*.certSigningRequest
*.mobileprovision
*.provisionprofile
*.keychain
*.keychain-db

# Private keys & credentials (test fixtures excluded via Reference/ rule below)
*.key
*.pem
*.p8
id_rsa
id_ed25519

# ──────────────────────── macOS / Finder ──────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ──────────────────────── Xcode build output ──────────────────────
build/
DerivedData/
*.moved-aside
*.hmap
*.ipa
*.dSYM.zip
*.dSYM
*.xcarchive

# Xcode per-user state (breakpoints, window layout, schemes, etc.)
xcuserdata/
*.xcuserstate
*.xcscmblueprint

# ──────────────────── Swift Package Manager ───────────────────────
.build/
.swiftpm/
Package.resolved

# ──────────────────── Dependency managers ─────────────────────────
# CocoaPods
Pods/
# Carthage
Carthage/Build/

# ──────────────── Vendored FreeRDP build artifacts ────────────────
# Generated by scripts/vendor-freerdp.sh. The FreeRDP source itself is
# tracked as a git submodule (ThirdParty/FreeRDP); only the build and
# install outputs are generated and must not be committed.
ThirdParty/FreeRDP-build/
ThirdParty/FreeRDP-install/

# ─────────────── Local reference material (not shipped) ────────────
# Source mirrors of other projects + third-party commercial DMG.
Reference/
